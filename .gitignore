# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================================================================
# CRITICAL: ENVIRONMENT & CREDENTIALS - NEVER COMMIT THESE!
# ============================================================================
.env
.env.local
.env.*.local
.env.*.php
.env.production
.env.development
.env.staging
backend/.env
frontend/.env
*.env.lock

# Sensitive credential files
*.key
*.pem
*.pfx
*.p12
secrets/
credentials/
*credentials.json
*token.json
.aws/
.ssh/

